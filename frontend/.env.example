# Public site URL — used for canonical URLs, OG tags, sitemap
VITE_SITE_URL=https://blazing8s.com

# Backend API (your VPS, with HTTPS)
VITE_API_URL=https://api.blazing8s.com

# Supabase (Lovable Cloud) — used for live realtime updates only.
# These are public/anon credentials — safe in client bundle.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...anon_public_key...
