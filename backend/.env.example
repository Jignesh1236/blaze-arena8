# Server
PORT=8080
# Comma-separated list of allowed origins for CORS (your Cloudflare Pages URL + custom domain)
CORS_ORIGINS=https://your-frontend.pages.dev,https://yourdomain.com

# Supabase (get from Lovable Cloud / Supabase project settings)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key...
